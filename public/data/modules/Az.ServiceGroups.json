{"module":"Az.ServiceGroups","version":"0.0.0","cmdlets":{"Get-AzServiceGroup":{"syntax":"Get-AzServiceGroup -Name <String> [-DefaultProfile <PSObject>]\n [<CommonParameters>]","examples":["Get-AzServiceGroup -Name \"Contoso\"","Gets the details of the service group named 'Contoso', including its display name, parent, and provisioning state."]},"Get-AzServiceGroupAncestor":{"syntax":"Get-AzServiceGroupAncestor -ServiceGroupName <String> [-DefaultProfile <PSObject>]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Get-AzServiceGroupAncestor -ServiceGroupName \"ContosoChild\""]},"New-AzServiceGroup":{"syntax":"New-AzServiceGroup -Name <String> [-DisplayName <String>] [-Kind <String>] [-ParentResourceId <String>]\n [-Tag <Hashtable>] [-DefaultProfile <PSObject>] [-AsJob] [-NoWait]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["New-AzServiceGroup -Name \"Contoso\" -DisplayName \"Contoso Group\" -ParentResourceId \"/providers/Microsoft.Management/serviceGroups/00000000-0000-0000-0000-000000000000\"","Creates a new service group named 'Contoso' under the root service group (tenant ID).\nThe groupId is a unique identifier that cannot be changed after creation.\nThe ParentResourceId must be the full Azure Resource Manager ID of the parent service group."]},"Remove-AzServiceGroup":{"syntax":"Remove-AzServiceGroup -Name <String> [-DefaultProfile <PSObject>] [-AsJob] [-NoWait] [-PassThru]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Remove-AzServiceGroup -Name \"Contoso\"","Get-AzServiceGroup -Name \"Contoso\" | Remove-AzServiceGroup -PassThru"]},"Update-AzServiceGroup":{"syntax":"Update-AzServiceGroup -Name <String> [-DisplayName <String>] [-ParentResourceId <String>] [-Tag <Hashtable>]\n [-DefaultProfile <PSObject>] [-AsJob] [-NoWait] [-WhatIf] [-Confirm]\n [<CommonParameters>]","examples":["Update-AzServiceGroup -Name \"Contoso\" -DisplayName \"Contoso Group Updated\"","Updates the display name of the 'Contoso' service group.\nThe update operation is asynchronous."]}}}