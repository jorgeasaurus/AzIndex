{"module":"Az.ArtifactSigning","version":"0.0.0","cmdlets":{"Get-AzArtifactSigningAccount":{"syntax":"Get-AzArtifactSigningAccount [-SubscriptionId <String[]>] [-DefaultProfile <PSObject>]\n [<CommonParameters>]","examples":["Get-AzArtifactSigningAccount -AccountName test -ResourceGroupName rg-test","This command get a artifact signing account by name."]},"Get-AzArtifactSigningCertificateChain":{"syntax":"Get-AzArtifactSigningCertificateChain [-AccountName] <String> [-ProfileName] <String> [-EndpointUrl] <String>\n [-Destination] <String> [-DefaultProfile <IAzureContextContainer>]\n [<CommonParameters>]","examples":["Get-AzArtifactSigningCertificateChain -AccountName 'contoso' -ProfileName 'contososigning' -EndpointUrl 'https://wus.artifactsigning.azure.net' -Destination 'c:\\acs\\certificatechain.der'","This command retrieves a certificate chain that is currently in use for signing by the account and profile."]},"Get-AzArtifactSigningCertificateProfile":{"syntax":"Get-AzArtifactSigningCertificateProfile -AccountName <String> -ResourceGroupName <String>\n [-SubscriptionId <String[]>] [-DefaultProfile <PSObject>]\n [<CommonParameters>]","examples":["Get-AzArtifactSigningCertificateProfile -AccountName test -ResourceGroupName rg-test -ProfileName test","This command gets a artifact signing certificate profile"]},"Get-AzArtifactSigningCertificateRoot":{"syntax":"Get-AzArtifactSigningCertificateRoot [-AccountName] <String> [-ProfileName] <String> [-EndpointUrl] <String>\n [-Destination] <String> [-DefaultProfile <IAzureContextContainer>]\n [<CommonParameters>]","examples":["Get-AzArtifactSigningCertificateRoot -AccountName 'contoso' -ProfileName 'contososigning' -EndpointUrl 'https://wus.artifactsigning.azure.net' -Destination 'c:\\acs\\certificateroot.cer'","This command retrieves a root certificate that is currently in use for signing by the account and profile."]},"Get-AzArtifactSigningCustomerEku":{"syntax":"Get-AzArtifactSigningCustomerEku [-AccountName] <String> [-ProfileName] <String> [-EndpointUrl] <String>\n [-DefaultProfile <IAzureContextContainer>] [<CommonParameters>]","examples":["Get-AzArtifactSigningCustomerEku -AccountName 'contoso' -ProfileName 'contososigning' -EndpointUrl 'https://wus.codesigning.azure.net'","This command retrieves the customer eku by account and profile name."]},"Invoke-AzArtifactSigningCIPolicySigning":{"syntax":"Invoke-AzArtifactSigningCIPolicySigning [-AccountName] <String> [-ProfileName] <String> [-EndpointUrl] <String>\n [-Path] <String> -Destination <String> [-TimeStamperUrl <String>] [-DefaultProfile <IAzureContextContainer>]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Invoke-AzArtifactSigningCIPolicySigning -AccountName 'contoso' -ProfileName 'contososigning' -EndpointUrl 'https://wus.artifactsigning.azure.net' -Path 'c:\\cisigning\\contosocipolicy.bin' -Destination 'c:\\cisigning\\signed_contosocipolicy.bin' -TimeStamperUrl 'http://timestamp.acs.microsoft.com'","This command signs a CI policy by account and profile, it also timestamps the signature using the timestamp url provided."]},"New-AzArtifactSigningAccount":{"syntax":"New-AzArtifactSigningAccount -AccountName <String> -ResourceGroupName <String> [-SubscriptionId <String>]\n -Location <String> [-SkuName <String>] [-Tag <Hashtable>] [-DefaultProfile <PSObject>] [-AsJob] [-NoWait]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["New-AzArtifactSigningAccount -AccountName test -ResourceGroupName rg-test -Location eastus -SkuName Basic","This command creates a new artifact signing account with a Basic SKU"]},"New-AzArtifactSigningCertificateProfile":{"syntax":"New-AzArtifactSigningCertificateProfile -AccountName <String> -ProfileName <String> -ResourceGroupName <String>\n [-SubscriptionId <String>] [-IdentityValidationId <String>] [-IncludeCity] [-IncludeCountry]\n [-IncludePostalCode] [-IncludeState] [-IncludeStreetAddress] [-ProfileType <String>]\n [-DefaultProfile <PSObject>] [-AsJob] [-NoWait] [-WhatIf] [-Confirm]\n [<CommonParameters>]","examples":["New-AzArtifactSigningCertificateProfile -AccountName test -ResourceGroupName rg-test -ProfileName test -IdentityValidationId 5ab4583e-d027-4998-9d65-a2e88981829f -ProfileType PublicTrustTest"]},"Remove-AzArtifactSigningAccount":{"syntax":"Remove-AzArtifactSigningAccount -AccountName <String> -ResourceGroupName <String> [-SubscriptionId <String>]\n [-DefaultProfile <PSObject>] [-AsJob] [-NoWait] [-PassThru] [-WhatIf]\n [-Confirm] [<CommonParameters>]","examples":["Remove-AzArtifactSigningAccount -AccountName test -ResourceGroupName rg-test"]},"Remove-AzArtifactSigningCertificateProfile":{"syntax":"Remove-AzArtifactSigningCertificateProfile -AccountName <String> -ProfileName <String>\n -ResourceGroupName <String> [-SubscriptionId <String>] [-DefaultProfile <PSObject>] [-AsJob] [-NoWait]\n [-PassThru] [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Remove-AzArtifactSigningCertificateProfile -AccountName test -ResourceGroupName test -ProfileName test"]},"Test-AzArtifactSigningAccountNameAvailability":{"syntax":"Test-AzArtifactSigningAccountNameAvailability [-SubscriptionId <String>] -Name <String> -Type <String>\n [-DefaultProfile <PSObject>] [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Test-AzArtifactSigningAccountNameAvailability -Name unavaliable","This commands tests the availability of artifact signing account name `unavaliable`.\nThe results shows `unavaliable` is occupied."]},"Update-AzArtifactSigningAccount":{"syntax":"Update-AzArtifactSigningAccount -AccountName <String> -ResourceGroupName <String> [-SubscriptionId <String>]\n [-SkuName <String>] [-Tag <Hashtable>] [-DefaultProfile <PSObject>] [-AsJob] [-NoWait]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Update-AzArtifactSigningAccount -AccountName test -ResourceGroupName rg-test -SkuName Premium","This command updates a Artifact signing Account SKU from Basic to Premium"]}}}