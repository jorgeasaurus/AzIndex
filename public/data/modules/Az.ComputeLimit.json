{"module":"Az.ComputeLimit","version":"0.0.0","cmdlets":{"Add-AzGuestSubscription":{"syntax":"Add-AzGuestSubscription -Id <String> -Location <String> [-SubscriptionId <String>] [-DefaultProfile <PSObject>]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Add-AzGuestSubscription -Location \"eastus\" -Id \"00000000-0000-0000-0000-000000000001\"","Adds a subscription as a guest to consume the compute limits shared by the host subscription."]},"Add-AzSharedLimit":{"syntax":"Add-AzSharedLimit -Location <String> -Name <String> [-SubscriptionId <String>] [-DefaultProfile <PSObject>]\n [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Add-AzSharedLimit -Location \"eastus\" -Name \"mySharedLimit\"","Enables sharing of a compute limit by the host subscription with its guest subscriptions in the specified location."]},"Get-AzGuestSubscription":{"syntax":"Get-AzGuestSubscription -Location <String> [-SubscriptionId <String[]>] [-DefaultProfile <PSObject>]\n [<CommonParameters>]","examples":["Get-AzGuestSubscription -Location \"eastus\"","Lists all guest subscriptions consuming shared compute limits in the specified location."]},"Get-AzSharedLimit":{"syntax":"Get-AzSharedLimit -Location <String> [-SubscriptionId <String[]>] [-DefaultProfile <PSObject>]\n [<CommonParameters>]","examples":["Get-AzSharedLimit -Location \"eastus\"","Lists all compute limits shared by the host subscription in the East US region."]},"Remove-AzGuestSubscription":{"syntax":"Remove-AzGuestSubscription -Id <String> -Location <String> [-SubscriptionId <String>]\n [-DefaultProfile <PSObject>] [-PassThru] [-WhatIf] [-Confirm]\n [<CommonParameters>]","examples":["Remove-AzGuestSubscription -Location \"eastus\" -Id \"00000000-0000-0000-0000-000000000001\"","Remove-AzGuestSubscription -Location \"eastus\" -Id \"00000000-0000-0000-0000-000000000001\" -PassThru -Confirm:$false"]},"Remove-AzSharedLimit":{"syntax":"Remove-AzSharedLimit -Location <String> -Name <String> [-SubscriptionId <String>] [-DefaultProfile <PSObject>]\n [-PassThru] [-WhatIf] [-Confirm] [<CommonParameters>]","examples":["Remove-AzSharedLimit -Location \"eastus\" -Name \"mySharedLimit\"","Remove-AzSharedLimit -Location \"eastus\" -Name \"mySharedLimit\" -PassThru -Confirm:$false"]}}}